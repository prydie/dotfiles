    hugo
    picocom
    shellcheck
    shfmt
    z3
  )

  os::ubuntu::ensure_1password_repo
  sudo apt update
  sudo apt install -y --no-install-recommends "${dev_packages[@]}"
  tools::install_opentofu
  go::ensure_installed
  tools::install_mise_dev_tools
  go::install_developer_tools
  tools::install_tla_tools
  if [ -f "${_ROOT}/hooks/kubernetes" ]; then
    BIN_DIR="${HOME}/bin"
    mkdir -p "${BIN_DIR}"
    # shellcheck source=hooks/kubernetes
    . "${_ROOT}/hooks/kubernetes"
    kube::install_zsh_completion kubebuilder
    kube::install_zsh_completion helm
    kube::install_zsh_completion kind
  fi
  tools::configure_helm_repos
  tools::install_esp_tools

  # Keep fast-moving JS/Python tooling current from upstream registries.
  nvm::install_node_default
  mkdir -p "${HOME}/.local/bin"
  npm install -g --prefix "${HOME}/.local" \
    @anthropic-ai/claude-code \
    @google/gemini-cli \
    @openai/codex \
    @ansible/ansible-language-server \
    bash-language-server \
    dockerfile-language-server-nodejs \
    eslint_d \
    prettier \
    pyright \
    vscode-langservers-extracted \
    yaml-language-server
  tools::install_codex_superpowers_optional
  tools::verify_dev_cli
}

tools::configure_helm_repos() {
  # Register the public chart repos used across NKS work. Idempotent:
  # --force-update replaces any existing entry rather than erroring, and Helm
  # rewrites ~/.config/helm/repositories.yaml itself, so we do not track it.
  command -v helm >/dev/null 2>&1 || return 0

  helm repo add jetstack https://charts.jetstack.io --force-update
  helm repo add prometheus-community https://prometheus-community.github.io/helm-charts --force-update
  helm repo update jetstack prometheus-community
}

os::set_zoom_scaling_factor () {
  perl -i -pe 's/scaleFactor=2/scaleFactor=1/' ~/.config/zoomus.conf
}

tools::install_codex_superpowers() {
  local codex_bin

  if ! codex_bin="$(tools::plugin_capable_codex_bin)"; then
    log::e "No Codex CLI with plugin install support found"
    log::e "Update Codex first, then rerun: make codex-superpowers"
    return 1
  fi

  if "${codex_bin}" plugin list 2>/dev/null | grep -q "superpowers@openai-curated (installed, enabled)"; then
    log::f "Codex Superpowers plugin already installed"
    return 0
  fi

  "${codex_bin}" plugin add superpowers@openai-curated
}

tools::install_codex_superpowers_optional() {
  if tools::install_codex_superpowers; then
    return 0
  fi

  log::f "Skipping Codex Superpowers plugin during bootstrap; rerun make codex-superpowers after Codex is healthy"
  return 0
}

tools::plugin_capable_codex_bin() {
  local candidate resolved

  resolved="$(command -v codex 2>/dev/null || true)"
  for candidate in \
    "${resolved}" \
    "${HOME}"/.nvm/versions/node/*/bin/codex \
    "${HOME}/.local/bin/codex"
  do
    if [ -z "${candidate}" ] || [ ! -x "${candidate}" ]; then
      continue
    fi

    if "${candidate}" plugin --help 2>/dev/null | grep -q "^  add "; then
      printf "%s\n" "${candidate}"
      return 0
    fi
  done

  return 1
}

tools::verify_codex_superpowers() {
  local codex_bin

  if ! codex_bin="$(tools::plugin_capable_codex_bin)"; then
    log::e "Codex plugin-capable CLI not found"
    return 1
  fi

  if "${codex_bin}" plugin list 2>/dev/null | grep -q "superpowers@openai-curated (installed, enabled)"; then
    log::f "Codex Superpowers plugin: installed and enabled"
    return 0
  fi

  log::e "Codex Superpowers plugin not installed"
  return 1
}

tools::verify_codex_superpowers_optional() {
  tools::verify_codex_superpowers || true
}

go::install_developer_tools() {
  local modvendor_version golangci_lint_version govulncheck_version gopls_version
  modvendor_version="${MODVENDOR_VERSION:-v0.5.0}"
  golangci_lint_version="${GOLANGCI_LINT_VERSION:-v2.8.0}"
  govulncheck_version="${GOVULNCHECK_VERSION:-latest}"
  gopls_version="${GPLS_VERSION:-latest}"

  go install "github.com/goware/modvendor@${modvendor_version}"
  go install "github.com/golangci/golangci-lint/v2/cmd/golangci-lint@${golangci_lint_version}"
  go install "golang.org/x/vuln/cmd/govulncheck@${govulncheck_version}"
  go install "golang.org/x/tools/gopls@${gopls_version}"
}

go::install_local() {
  local version min_version arch os_name tmpdir tarball install_root download_version
  min_version="${GO_MIN_VERSION:-1.23.0}"
  version="${GO_VERSION:-}"
  arch="${ARCH}"
  os_name="linux"
  install_root="${HOME}/.local/opt/go"
  local opt_root
  opt_root="${HOME}/.local/opt"

  case "${arch}" in
    amd64|arm64) ;;
    *)
      log::e "Unsupported architecture for local Go install: ${arch}"
      return 1
      ;;
  esac

  if [ -z "${version}" ]; then
    version="$(curl -fsSL 'https://go.dev/VERSION?m=text' | sed -n '1s/^go//p')"
  fi

  if [[ "${version}" == go* ]]; then
    version="${version#go}"
  fi

  if ! version::ge "${version}" "${min_version}"; then
    log::e "Resolved Go version ${version} is below required minimum ${min_version}"
    return 1
  fi

  download_version="go${version}"
  tmpdir="$(mktemp -d)"
  tarball="${tmpdir}/${download_version}.${os_name}-${arch}.tar.gz"

  log::f "Installing ${download_version} to ${install_root}"
  curl -fsSL -o "${tarball}" "https://go.dev/dl/${download_version}.${os_name}-${arch}.tar.gz"
  rm -rf "${install_root}"
  mkdir -p "${opt_root}" "${HOME}/.local/bin"
  tar -xzf "${tarball}" -C "${opt_root}"
  ln -sf "${install_root}/bin/go" "${HOME}/.local/bin/go"
  ln -sf "${install_root}/bin/gofmt" "${HOME}/.local/bin/gofmt"
  rm -rf "${tmpdir}"
}

go::ensure_installed() {
  local current_version min_version
  min_version="${GO_MIN_VERSION:-1.23.0}"

  if command -v go >/dev/null 2>&1; then
    current_version="$(go version | awk '{print $3}' | sed 's/^go//')"
    if version::ge "${current_version}" "${min_version}"; then
      log::f "Go already installed: $(go version)"
      return 0
    fi

    log::f "Go ${current_version} detected; upgrading to >= ${min_version}"
  else
    log::f "Go not found; installing >= ${min_version}"
  fi

  if go::install_local; then
    log::f "Using Go $(go version)"
    return 0
  fi

  log::e "Failed to install Go from official binaries"
  return 1
}

tools::github_release_url() {
  local repo version artifact
  repo="$1"
  version="$2"
  artifact="$3"

  if [ "${version}" = "latest" ]; then
    printf "https://github.com/%s/releases/latest/download/%s\n" "${repo}" "${artifact}"
  else
    printf "https://github.com/%s/releases/download/%s/%s\n" "${repo}" "${version}" "${artifact}"
  fi
}

tools::write_tla_java_wrapper() {
  local name main_class wrapper
  name="$1"
  main_class="$2"
  wrapper="${HOME}/.local/bin/${name}"

  mkdir -p "${HOME}/.local/bin" || return 1
  # shellcheck disable=SC2016
  {
    printf '#!/usr/bin/env bash\n'
    printf 'set -euo pipefail\n'
    printf 'jar="${TLA_TOOLS_JAR:-${HOME}/.local/opt/tlaplus/tla2tools.jar}"\n'
    printf 'if [ ! -f "${jar}" ]; then\n'
    printf '  echo "tla2tools.jar not found at ${jar}; run: make -C ~/.dotfiles tla-tools" >&2\n'
    printf '  exit 1\n'
    printf 'fi\n'
    printf 'exec java -XX:+UseParallelGC -cp "${jar}" %s "$@"\n' "${main_class}"
  } > "${wrapper}"
  chmod 0755 "${wrapper}"
}

tools::write_tla2tools_wrapper() {
  local wrapper
  wrapper="${HOME}/.local/bin/tla2tools"

  mkdir -p "${HOME}/.local/bin" || return 1
  # shellcheck disable=SC2016
  {
    printf '#!/usr/bin/env bash\n'
    printf 'set -euo pipefail\n'
    printf 'jar="${TLA_TOOLS_JAR:-${HOME}/.local/opt/tlaplus/tla2tools.jar}"\n'
    printf 'if [ ! -f "${jar}" ]; then\n'
    printf '  echo "tla2tools.jar not found at ${jar}; run: make -C ~/.dotfiles tla-tools" >&2\n'
    printf '  exit 1\n'
    printf 'fi\n'
    printf 'exec java -XX:+UseParallelGC -jar "${jar}" "$@"\n'
  } > "${wrapper}"
  chmod 0755 "${wrapper}"
}

tools::install_tla2tools() {
  local version install_root jar url tmp
  version="${TLA_TOOLS_VERSION:-latest}"
  install_root="${TLA_TOOLS_HOME:-${HOME}/.local/opt/tlaplus}"
  jar="${install_root}/tla2tools.jar"
  url="$(tools::github_release_url "tlaplus/tlaplus" "${version}" "tla2tools.jar")"

  if [ -f "${jar}" ] && [ "${TLA_TOOLS_FORCE:-0}" != "1" ]; then
    log::f "TLA+ tools jar already installed at ${jar}"
  else
    log::f "Installing TLA+ tools jar from ${url}"
    tmp="$(mktemp)" || return 1
    curl -fsSL -o "${tmp}" "${url}" || {
      rm -f "${tmp}"
      return 1
    }
    mkdir -p "${install_root}" || return 1
    install -m 0644 "${tmp}" "${jar}" || {
      rm -f "${tmp}"
      return 1
    }
    rm -f "${tmp}"
  fi

  tools::write_tla2tools_wrapper || return 1
  tools::write_tla_java_wrapper tlc tlc2.TLC || return 1
  tools::write_tla_java_wrapper sany tla2sany.SANY || return 1
  tools::write_tla_java_wrapper pcal pcal.trans || return 1
  tools::write_tla_java_wrapper tla2tex tla2tex.TLA || return 1
  tools::write_tla_java_wrapper tlatex tla2tex.TLA || return 1
  tools::write_tla_java_wrapper tlarepl tlc2.REPL || return 1
}

tools::install_apalache() {
  local version install_root url tmp tarball
  version="${APALACHE_VERSION:-latest}"
  install_root="${APALACHE_HOME:-${HOME}/.local/opt/apalache}"
  url="$(tools::github_release_url "apalache-mc/apalache" "${version}" "apalache.tgz")"

  if [ -x "${install_root}/bin/apalache-mc" ] && [ "${APALACHE_FORCE:-0}" != "1" ]; then
    log::f "Apalache already installed at ${install_root}"
  else
    log::f "Installing Apalache from ${url}"
    tmp="$(mktemp -d)" || return 1
    tarball="${tmp}/apalache.tgz"
    curl -fsSL -o "${tarball}" "${url}" || {
      rm -rf "${tmp}"
      return 1
    }
    rm -rf "${install_root}" || return 1
    mkdir -p "${install_root}" || return 1
    tar -xzf "${tarball}" -C "${install_root}" --strip-components=1 || {
      rm -rf "${tmp}"
      return 1
    }
    rm -rf "${tmp}"
  fi

  mkdir -p "${HOME}/.local/bin" || return 1
  ln -sf "${install_root}/bin/apalache-mc" "${HOME}/.local/bin/apalache-mc" || return 1
}

tools::install_tlaps() {
  local version release_tag install_root arch url tmp installer
  version="${TLAPS_VERSION:-1.5.0}"
  release_tag="${TLAPS_RELEASE_TAG:-202210041448}"
  install_root="${TLAPS_HOME:-${HOME}/.local/opt/tlaps}"
  arch="$(uname -m)"

  case "${arch}" in
    x86_64|amd64) ;;
    *)
      log::e "TLAPS binary installer supports x86_64 Linux only; unsupported architecture: ${arch}"
      return 1
      ;;
  esac

  if [ -x "${install_root}/bin/tlapm" ] && [ "${TLAPS_FORCE:-0}" != "1" ]; then
    log::f "TLAPS already installed at ${install_root}"
  else
    url="https://github.com/tlaplus/tlapm/releases/download/${release_tag}/tlaps-${version}-x86_64-linux-gnu-inst.bin"
    log::f "Installing TLAPS from ${url}"
    tmp="$(mktemp -d)" || return 1
    installer="${tmp}/tlaps-inst.bin"
    curl -fsSL -o "${installer}" "${url}" || {
      rm -rf "${tmp}"
      return 1
    }
    chmod 0755 "${installer}" || return 1
    mkdir -p "$(dirname "${install_root}")" || return 1
    "${installer}" -d "${install_root}" || {
      rm -rf "${tmp}"
      return 1
    }
    rm -rf "${tmp}"
  fi

  mkdir -p "${HOME}/.local/bin" || return 1
  ln -sf "${install_root}/bin/tlapm" "${HOME}/.local/bin/tlapm" || return 1
}

tools::install_tla_rs() {
  local version platform base tmp
  version="${TLA_RS_VERSION:-v0.6.3}"

  case "$(uname -m)" in
    x86_64|amd64) platform="linux-amd64" ;;
    *)
      log::e "tla-rs binary installer supports x86_64 Linux only; unsupported architecture: $(uname -m)"
      return 1
      ;;
  esac

  if [ -x "${HOME}/.local/bin/tla" ] && [ -x "${HOME}/.local/bin/tla-mcp" ] && [ "${TLA_RS_FORCE:-0}" != "1" ]; then
    log::f "tla-rs already installed at ${HOME}/.local/bin/tla and ${HOME}/.local/bin/tla-mcp"
    return 0
  fi

  base="https://github.com/fabracht/tla-rs/releases/download/${version}"
  tmp="$(mktemp -d)" || return 1

  log::f "Installing tla-rs ${version} from ${base}"
  curl -fsSL -o "${tmp}/SHA256SUMS" "${base}/SHA256SUMS" || {
    rm -rf "${tmp}"
    return 1
  }
  curl -fsSL -o "${tmp}/tla-${platform}" "${base}/tla-${platform}" || {
    rm -rf "${tmp}"
    return 1
  }
  curl -fsSL -o "${tmp}/tla-mcp-${platform}" "${base}/tla-mcp-${platform}" || {
    rm -rf "${tmp}"
    return 1
  }

  (
    cd "${tmp}" || exit 1
    grep -E " (tla|tla-mcp)-${platform}$" SHA256SUMS | sha256sum -c -
  ) || {
    rm -rf "${tmp}"
    return 1
  }

  mkdir -p "${HOME}/.local/bin" || return 1
  install -m 0755 "${tmp}/tla-${platform}" "${HOME}/.local/bin/tla" || {
    rm -rf "${tmp}"
    return 1
  }
  install -m 0755 "${tmp}/tla-mcp-${platform}" "${HOME}/.local/bin/tla-mcp" || {
    rm -rf "${tmp}"
    return 1
  }
  rm -rf "${tmp}"
}

tools::ensure_tla_runtime_deps() {
  local missing=()

  command -v java >/dev/null 2>&1 || missing+=(default-jre-headless)
  command -v z3 >/dev/null 2>&1 || missing+=(z3)

  if [ "${#missing[@]}" -eq 0 ]; then
    return 0
  fi

  if ! command -v apt-get >/dev/null 2>&1; then
    log::e "Missing TLA+ runtime dependencies and apt-get is unavailable: ${missing[*]}"
    return 1
  fi

  log::f "Installing TLA+ runtime dependencies: ${missing[*]}"
  sudo apt update || return 1
  apt::install_if_available "${missing[@]}" || return 1

  command -v java >/dev/null 2>&1 || {
    log::e "java not found on PATH after installing TLA+ runtime dependencies"
    return 1
  }
  command -v z3 >/dev/null 2>&1 || {
    log::e "z3 not found on PATH after installing TLA+ runtime dependencies"
    return 1
  }
}

tools::install_tla_tools() {
  tools::ensure_tla_runtime_deps || return 1

  tools::install_tla2tools || return 1
  tools::install_apalache || return 1
  tools::install_tlaps || return 1
  tools::install_tla_rs || return 1
  tools::verify_tla_tools
}

tools::verify_tla_command() {
  local name cmd check output status first_line path
  name="$1"
  cmd="$2"
  check="$3"

  if ! command -v "${cmd}" >/dev/null 2>&1; then
    log::e "${name} not found on PATH"
    return 1
  fi

  output="$({ eval "${check}"; } 2>&1)"
  status=$?
  first_line="$(sed -n '1p' <<<"${output}")"
  if [ "${status}" -ne 0 ]; then
    log::e "${name} check failed: ${first_line:-no output}"
    return 1
  fi

  path="$(command -v "${cmd}")"
  log::f "${name}: ${first_line:-ok} (${path})"
}

tools::write_tla_smoke_model() {
  local dir
  dir="$1"

  cat > "${dir}/Smoke.tla" <<'EOF'
---- MODULE Smoke ----
EXTENDS Naturals
VARIABLE
  \* @type: Int;
  x
Init == x = 0
Next == \/ x < 2 /\ x' = x + 1
        \/ x = 2 /\ x' = x
Inv == x <= 2
====
EOF

  cat > "${dir}/Smoke.cfg" <<'EOF'
INIT Init
NEXT Next
INVARIANT Inv
EOF
}

tools::verify_tla_smoke_command() {
  local name cmd tmp output status first_line path
  name="$1"
  shift
  cmd="$1"

  if ! command -v "${cmd}" >/dev/null 2>&1; then
    log::e "${name} not found on PATH"
    return 1
  fi

  tmp="$(mktemp -d)"
  tools::write_tla_smoke_model "${tmp}"
  output="$(cd "${tmp}" && "$@" 2>&1)"
  status=$?
  rm -rf "${tmp}"

  first_line="$(sed -n '/[^[:space:]]/ {p; q;}' <<<"${output}")"
  if [ "${status}" -ne 0 ]; then
    log::e "${name} smoke check failed: ${first_line:-no output}"
    return 1
  fi

  path="$(command -v "${cmd}")"
  log::f "${name}: smoke check passed (${path})"
}

tools::verify_tlaps_smoke() {
  local tmp output status first_line path

  if ! command -v tlapm >/dev/null 2>&1; then
    log::e "TLAPS not found on PATH"
    return 1
  fi

  tmp="$(mktemp -d)"
  output="$(cd "${tmp}" && tlapm -C -I +examples/cantor Cantor1.tla 2>&1)"
  status=$?
  rm -rf "${tmp}"

  first_line="$(sed -n '/[^[:space:]]/ {p; q;}' <<<"${output}")"
  if [ "${status}" -ne 0 ]; then
    log::e "TLAPS proof smoke check failed: ${first_line:-no output}"
    return 1
  fi

  path="$(command -v tlapm)"
  log::f "TLAPS: proof smoke check passed (${path})"
}

tools::verify_tla_mcp() {
  local output status path

  if ! command -v tla-mcp >/dev/null 2>&1; then
    log::e "tla-mcp not found on PATH"
    return 1
  fi

  output="$(tla-mcp </dev/null 2>&1)"
  status=$?
  if [ "${status}" -ne 1 ] || ! grep -q 'ConnectionClosed("initialize request")' <<<"${output}"; then
    log::e "tla-mcp stdio smoke check failed: ${output:-no output}"
    return 1
  fi

  path="$(command -v tla-mcp)"
  log::f "tla-mcp: stdio smoke check passed (${path})"
}

tools::verify_tla_tools() {
  local failures=0
  log::f "Verifying TLA+ validation/proof CLIs"

  tools::verify_tla_command "Java" "java" "java -version" || failures=1
  tools::verify_tla_smoke_command "SANY" "sany" "Smoke.tla" || failures=1
  tools::verify_tla_smoke_command "TLC" "tlc" "Smoke.tla" || failures=1
  tools::verify_tla_command "PlusCal translator" "pcal" "pcal -help" || failures=1
  tools::verify_tla_command "TLATeX" "tla2tex" "tla2tex -help" || failures=1
  tools::verify_tla_smoke_command "Apalache" "apalache-mc" "check" "--length=2" "--inv=Inv" "Smoke.tla" || failures=1
  tools::verify_tlaps_smoke || failures=1
  tools::verify_tla_smoke_command "tla-rs" "tla" "Smoke.tla" "--config" "Smoke.cfg" "--max-states" "100" "--max-depth" "10" || failures=1
  tools::verify_tla_mcp || failures=1

  return "${failures}"
}



# Tools
#######

tools::install_terraform() {
  local VERSION=v1.4.6

  local out
  out="$(mktemp)"
  curl -sfLo "${out}" "https://releases.hashicorp.com/terraform/${VERSION:1}/terraform_${VERSION:1}_linux_${ARCH}.zip"
  sudo unzip "${out}" -d /usr/local/bin/
}

tools::install_ansible() {
  # sudo apt-add-repository -y ppa:ansible/ansible
  sudo apt update
  sudo apt install -y ansible
}

tools::wireshark() {
  # sudo add-apt-repository ppa:wireshark-dev/stable -y
  sudo apt update
  echo "wireshark-common wireshark-common/install-setuid boolean true" | sudo debconf-set-selections
  DEBIAN_FRONTEND=noninteractive sudo apt install -y wireshark
}

tools::install_opentofu() {
  if command -v tofu >/dev/null 2>&1; then
    log::f "OpenTofu already installed: $(tofu --version | head -n1)"
    return 0
  fi

  log::f "Installing OpenTofu from apt"
  os::ubuntu::ensure_opentofu_repo
  sudo apt update
  sudo apt install -y --no-install-recommends tofu
}

tools::install_esp_tools() {
  log::f "Bootstrapping ESP-IDF helpers"

  local idf_root
  idf_root="${HOME}/.espressif/esp-idf"
  if [ ! -d "${idf_root}" ]; then
    mkdir -p "${HOME}/.espressif"
    git clone --depth 1 https://github.com/espressif/esp-idf.git "${idf_root}"
  fi

  if [ -f "${idf_root}/tools/idf.py" ]; then
    mkdir -p "${HOME}/.local/bin"
    ln -sf "${idf_root}/tools/idf.py" "${HOME}/.local/bin/idf.py"
    chmod +x "${idf_root}/tools/idf.py" || true
  fi
}

tools::verify_one() {
  local name cmd version_cmd version path
  name="$1"
  cmd="$2"
  version_cmd="$3"

  if command -v "${cmd}" >/dev/null 2>&1; then
    version="$(eval "${version_cmd}" 2>/dev/null | head -n1)"
    path="$(command -v "${cmd}")"
    log::f "${name}: ${version:-version unknown} (${path})"
  else
    log::e "${name} not found on PATH"
  fi
}

tools::verify_openstack_octavia() {
  if openstack loadbalancer list --help >/dev/null 2>&1; then
    log::f "OpenStack Octavia plugin: loadbalancer commands available"
  else
    log::e "OpenStack Octavia plugin not found; reinstall pipx:python-openstackclient from mise"
  fi
}

tools::verify_dev_cli() {
  log::f "Verifying key dev CLIs"
  tools::verify_one "mise" "mise" "mise --version"
  tools::verify_one "Codex CLI" "codex" "codex --version"
  tools::verify_codex_superpowers_optional
  tools::verify_one "Claude Code" "claude" "claude --version"
  tools::verify_one "Gemini CLI" "gemini" "gemini --version"
  tools::verify_one "Go" "go" "go version"
  tools::verify_one "gopls" "gopls" "gopls version"
  tools::verify_one "golangci-lint" "golangci-lint" "golangci-lint --version"
  tools::verify_one "govulncheck" "govulncheck" "govulncheck -version"
  tools::verify_one "OpenTofu" "tofu" "tofu --version"
  tools::verify_one "doctl" "doctl" "doctl version"
  tools::verify_one "AWS CLI" "aws" "aws --version"
  tools::verify_one "OpenStack CLI" "openstack" "openstack --version"
  tools::verify_openstack_octavia
  tools::verify_one "Helm" "helm" "helm version --short"
  tools::verify_one "Kubebuilder" "kubebuilder" "kubebuilder version"
  tools::verify_one "kind" "kind" "kind version"
  tools::verify_one "promtool" "promtool" "promtool --version"
  tools::verify_one "tsh" "tsh" "tsh version"
  tools::verify_one "Vale" "vale" "vale --version"
  tools::verify_tla_tools
}

tools::install_yubikey_manager() {
  if command -v ykman >/dev/null 2>&1; then
    log::f "yubikey-manager already installed: $(ykman --version 2>/dev/null | head -n1)"
    return 0
  fi

  if apt-cache show yubikey-manager >/dev/null 2>&1; then
    log::f "Installing yubikey-manager from apt"
    sudo apt install -y --no-install-recommends yubikey-manager pcscd || true
  fi

  if command -v ykman >/dev/null 2>&1; then
    return 0
  fi

  log::f "Installing yubikey-manager via uv tool fallback"
  if ! uv tool install --force --upgrade yubikey-manager; then
    log::f "Skipping yubikey-manager: uv install failed (likely missing optional smartcard build/runtime deps)"
  fi
}

os::install_dell_dock_fix() {
  log::f "Installing managed Dell dock mitigation hooks"

  sudo install -m 0755 -D "${_ROOT}/tools/dell_dock_fix.sh" /usr/local/sbin/dell-dock-fix
  sudo install -m 0755 -D "${_ROOT}/config/dell-dock/99-dell-dock-fix.dispatcher" /etc/NetworkManager/dispatcher.d/99-dell-dock-fix
  sudo install -m 0644 -D "${_ROOT}/config/dell-dock/99-dell-dock-fix.rules" /etc/udev/rules.d/99-dell-dock-fix.rules
  sudo install -m 0755 -D "${_ROOT}/config/dell-dock/99-dell-dock-fix.sleep" /usr/lib/systemd/system-sleep/99-dell-dock-fix

  sudo udevadm control --reload
  if command -v udevadm >/dev/null 2>&1; then
    sudo udevadm trigger --subsystem-match=net --action=add || true
  fi
}

os::ghostty::install_terminfo() {
  # Ghostty advertises TERM=xterm-ghostty, whose terminfo ships only inside the
  # Ghostty app. Install it into the user terminfo db so tmux/vim work when this
  # host is reached over SSH from a Ghostty terminal (otherwise: "missing or
  # unsuitable terminal: xterm-ghostty"). Sourced from the repo so it works on
  # hosts that do not have Ghostty itself installed.
  local src dest
  src="${_ROOT}/config/ghostty/xterm-ghostty.terminfo"

  if [ ! -f "${src}" ]; then
    log::f "Ghostty terminfo source missing at ${src}; skipping"
    return 0
  fi
  if ! command -v tic >/dev/null 2>&1; then
    log::f "tic not found (install ncurses-bin); skipping Ghostty terminfo"
    return 0
  fi
  if infocmp xterm-ghostty >/dev/null 2>&1 && [ "${GHOSTTY_TERMINFO_FORCE:-0}" != "1" ]; then
    log::f "Ghostty terminfo already present (xterm-ghostty)"
    return 0
  fi

  dest="${HOME}/.terminfo"
  log::f "Installing Ghostty terminfo (xterm-ghostty) into ${dest}"
  tic -x -o "${dest}" "${src}" 2>/dev/null || {
    log::e "Failed to install Ghostty terminfo from ${src}"
    return 1
  }
}

tools::full_install() {
  go::install_developer_tools
  tools::install_ansible
  tools::wireshark
  uv::ensure_installed
  tools::install_mise_full_tools
  tools::install_yubikey_manager
  os::install_dell_dock_fix
}

if [[ "${BASH_SOURCE[0]}" == "$0" ]]; then
  case "${1:-}" in
    codex-superpowers)
      tools::install_codex_superpowers
      ;;
    tmux-plugins)
      tools::install_tmux_plugins
      ;;
    tla-tools)
      tools::install_tla_tools
      ;;
    verify-tla-tools)
      tools::verify_tla_tools
      ;;
    full-install)
      tools::full_install
      ;;
    ghostty)
      tools::install_ghostty
      os::ghostty::install_terminfo
      ;;
    install-dell-dock-fix)
      os::install_dell_dock_fix
      ;;
    ghostty-terminfo)
      os::ghostty::install_terminfo
      ;;
    "")
      echo "No action selected. Use: $0 codex-superpowers | tmux-plugins | tla-tools | verify-tla-tools | full-install | ghostty | install-dell-dock-fix | ghostty-terminfo"
      ;;
    *)
      echo "Unknown action: $1"
      echo "Usage: $0 codex-superpowers | tmux-plugins | tla-tools | verify-tla-tools | full-install | ghostty | install-dell-dock-fix | ghostty-terminfo"
      exit 1
      ;;
  esac
fi

