#!/usr/bin/env bash
# vim: set ft=sh:

set -euo pipefail

_ROOT="$(dirname "${BASH_SOURCE[0]}")/.."

# Setup options:
# - PROFILE=link|core|dev|full (default: link)
# - SHELL_DEFAULT=1|0 (default: 1)
# - NODE_VERSION=<version> (default: lts/*)
PROFILE="${PROFILE:-link}"
SHELL_DEFAULT="${SHELL_DEFAULT:-1}"
NODE_VERSION="${NODE_VERSION:-lts/*}"
# hooks/os reads NVM_NODE_VERSION; map from the public interface.
export NVM_NODE_VERSION="${NODE_VERSION}"

touch "$HOME/.psqlrc.local"

. "${_ROOT}/hooks/os"

os::get_distro
case "${PROFILE}" in
  link|core|dev|full)
    ;;
  *)
    log::e "Unknown PROFILE=${PROFILE}. Supported: link, core, dev, full"
    exit 1
    ;;
esac

# Install Ghostty's terminfo on every profile (including link) so SSHing into
# this host from a Ghostty terminal does not break tmux/vim. User-level, cheap.
os::ghostty::install_terminfo || true

if [[ "${PROFILE}" != "link" ]]; then
  if [[ "${DISTRO}" =~ ^(Ubuntu|debian)$ ]]; then
    os::ensure_zsh

    if [[ "${SHELL_DEFAULT}" == "1" ]]; then
      os::ensure_user_shell_zsh
    else
      log::f "Skipping login shell update (set SHELL_DEFAULT=1 to enable)"
    fi

    log::f "Running setup profile=${PROFILE}"
    os::ubuntu::install_packages_core

    if [[ "${PROFILE}" == "dev" || "${PROFILE}" == "full" ]]; then
      os::ubuntu::install_packages_dev
    fi
  else
    log::e "Unsupported distribution ${DISTRO}"
    exit 1
  fi
else
  log::f "Profile link selected: skipping host package/tool installation"

  if [[ "${SHELL_DEFAULT}" == "1" ]]; then
    if command -v zsh >/dev/null 2>&1; then
      os::ensure_user_shell_zsh
    else
      log::f "Skipping login shell update: zsh not installed (use PROFILE=core or above)"
    fi
  else
    log::f "Skipping login shell update (set SHELL_DEFAULT=1 to enable)"
  fi
fi

if [[ "${PROFILE}" != "link" ]]; then
  # install zplug if not installed
  if [ ! -d "$HOME/.zplug" ]; then
    git clone https://github.com/zplug/zplug "$HOME/.zplug"
  fi
  if [ -s "$HOME/.zplug/init.zsh" ]; then
    if command -v zsh >/dev/null 2>&1; then
      # Install zplug plugins non-interactively so shell setup is fully bootstrapped.
      zsh -lc 'source "$HOME/.zplug/init.zsh"; zplug check || zplug install' || true
    else
      log::f "Skipping zplug bootstrap: zsh not installed"
    fi
  fi

  tools::install_tmux_plugins
else
  log::f "Skipping zplug/TPM bootstrap for PROFILE=link"
fi

if [ -f "$HOME/.config/zoomus.conf" ]; then
  os::set_zoom_scaling_factor
fi

if [[ "${PROFILE}" == "dev" || "${PROFILE}" == "full" ]]; then
  . "${_ROOT}/hooks/nvim"
else
  log::f "Skipping Neovim bootstrap (requires PROFILE=dev|full)"
fi

if [[ "${PROFILE}" == "full" ]]; then
  tools::full_install
else
  log::f "Skipping full tool installation (requires PROFILE=full)"
fi
