# Copy to ~/.config/restic-backup/env and adjust per machine.
#
# Examples:
#   RESTIC_REPOSITORY="sftp:backup@nas.lan:/volume1/restic/workstations"
#   RESTIC_REPOSITORY="/mnt/nas-backups/restic/workstations"
#
# For Synology over SFTP, enable SSH on the NAS and create a dedicated backup user.

RESTIC_REPOSITORY="sftp:backup@nas.lan:/volume1/restic/workstations"
RESTIC_PASSWORD_FILE="$HOME/.config/restic-backup/password"

# Optional explicit host label (defaults to hostname).
# RESTIC_HOST_LABEL="desktop"

# Optional retention policy for `restic-backup forget`.
RESTIC_KEEP_DAILY=7
RESTIC_KEEP_WEEKLY=4
RESTIC_KEEP_MONTHLY=6
RESTIC_KEEP_YEARLY=2

