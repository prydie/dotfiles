# Copy to ~/.config/nks-dev/env and edit locally.
# Keep real hostnames, ports, project IDs, credentials, and laptop-specific
# values out of this public dotfiles repository.

NKS_DEV_CLUSTER_NAME=nks-dev
NKS_DEV_KIND_IMAGE=kindest/node:v1.35.0@sha256:452d707d4862f52530247495d180205e029056831160e22870e37e3f6c1ac31f
NKS_DEV_KIND_CONTROL_PLANES=1
NKS_DEV_KIND_WORKERS=2
NKS_DEV_KIND_WAIT=5m
NKS_DEV_NODE_WAIT=3m

NKS_DEV_REGISTRY_ENABLED=1
NKS_DEV_REGISTRY_NAME=nks-dev-registry
NKS_DEV_REGISTRY_PORT=5001

# Optional: wrapper command for dev OpenStack checks, for example:
# NKS_DEV_OPENSTACK_CMD=uni-openstack

# Optional: reverse SSH tunnel for dev OpenStack instances that need to reach
# a service running on this workstation.
# NKS_DEV_TUNNEL_TARGET=dev-bastion.example
# NKS_DEV_TUNNEL_REMOTE_BIND=127.0.0.1
# NKS_DEV_TUNNEL_REMOTE_PORT=9443
# NKS_DEV_TUNNEL_LOCAL_HOST=127.0.0.1
# NKS_DEV_TUNNEL_LOCAL_PORT=9443
